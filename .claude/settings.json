{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx scripts/sync-rule-docs.ts",
            "if": "Edit(**/src/core/rules/**)"
          },
          {
            "type": "command",
            "command": "npx tsx scripts/sync-rule-docs.ts",
            "if": "Write(**/src/core/rules/**)"
          }
        ]
      }
    ]
  }
}
