{
  "name": "canicode",
  "version": "0.5.1",
  "description": "CLI tool that analyzes Figma design structures for development-friendliness and AI-friendliness scores",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "canicode": "dist/cli/index.js",
    "canicode-mcp": "dist/mcp/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:web": "tsup src/browser.ts --config tsup.browser.config.ts",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "build:plugin": "bash scripts/build-plugin.sh",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist",
    "docs/CUSTOMIZATION.md"
  ],
  "keywords": [
    "figma",
    "design",
    "analysis",
    "cli",
    "mcp",
    "readiness",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/let-sunny/canicode.git"
  },
  "author": "minseon",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@figma/rest-api-spec": "^0.36.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cac": "^7.0.0",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.123.0",
    "@types/node": "^25.5.0",
    "playwright": "^1.58.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
